# ===========================================
# API Configuration
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
PYTHONPATH=/app

# ===========================================
# IB Gateway Configuration
# ===========================================
IB_GATEWAY_URL=http://ibga:4000
IB_USERNAME=fiend6969
IB_PASSWORD=fj4T-U4FnouobkzN-UL7

# ===========================================
# Market Fetchers
# ===========================================
POLYMARKET_API_URL=https://clob.polymarket.com/markets
POLYMARKET_MAX_PAGES=100
PREDICTIT_API_URL=https://www.predictit.org/api/Markets
IBKR_ENABLED=true
POLYMARKET_ENABLED=true
PREDICTIT_ENABLED=true

# ===========================================
# Scanner Settings
# ===========================================
SCAN_MIN_ROI=0.1
SCAN_MIN_SIMILARITY=55.0
SCAN_TOP_K_MATCHES=2000
SCAN_AUTO_ENABLED=false

# ===========================================
# LLM / Ollama Configuration  
# ===========================================
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_WORKERS=4
OLLAMA_TIMEOUT=60
OLLAMA_VERIFICATION_CONFIDENCE=85

# ===========================================
# Cloud GPU / Colab
# ===========================================
NGROK_URL=https://your-ngrok-url.ngrok-free.dev
COLAB_MATCHES_TOP_K=2000

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=/tmp/arbitrage.log

