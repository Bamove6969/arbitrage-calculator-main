# Single Container Dockerfile for Arbitrage Scanner
# Everything in one: Backend + Ngrok + Colab Executor + Chromium
# ===========================================

FROM python:3.11-slim

WORKDIR /app

# Install ALL system dependencies upfront
RUN apt-get update && apt-get install -y \
    curl \
    git \
    wget \
    ca-certificates \
    gnupg \
    unzip \
    xvfb \
    # Chromium for Colab automation
    chromium \
    chromium-driver \
    # ngrok
    && wget -q https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-amd64.tgz \
    && tar -xzf ngrok-v3-stable-linux-amd64.tgz -C /usr/local/bin \
    && rm ngrok-v3-stable-linux-amd64.tgz \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast package installation
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Copy requirements first for better caching
COPY requirements.txt .
RUN uv pip install --system -r requirements.txt

# Install additional Python packages
RUN pip install \
    google-api-python-client \
    google-auth-httplib2 \
    google-auth-oauthlib \
    websockets \
    flask \
    selenium \
    webdriver-manager \
    nest_asyncio

# Copy the entire application
COPY backend/ backend/
COPY main.py .
COPY start.sh .
COPY AGENTS.md .
COPY Cloud_GPU_Matcher_v3_Auto.ipynb .
COPY colab_executor.py .

# Create directories
RUN mkdir -p /app/reports /app/data /app/logs

# Expose all ports
EXPOSE 8000 5000 4040

# Environment variables
ENV PYTHONPATH=/app
ENV IB_GATEWAY_URL=http://host.docker.internal:4001
ENV LLM_PROVIDER=openrouter
ENV DISPLAY=:99

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/api/health || exit 1

# Single entrypoint that starts everything
COPY docker-entrypoint-single.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
